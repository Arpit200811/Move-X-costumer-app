# ─── GOOGLE MAPS ────────────────────────────────────────────────────
# Get key from: https://console.cloud.google.com → Maps JavaScript API + Places API + Directions API
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIza_YOUR_GOOGLE_MAPS_API_KEY_HERE

# ─── STRIPE PAYMENT GATEWAY ─────────────────────────────────────────
# Get PUBLISHABLE key from: https://dashboard.stripe.com/apikeys  (starts with pk_test_ or pk_live_)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# ─── BACKEND CONFIG ──────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://movex-backend-hs2t.onrender.com/api
EXPO_PUBLIC_SOCKET_URL=https://movex-backend-hs2t.onrender.com
